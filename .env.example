# Get a free personal key at https://api.nasa.gov/ (arrives by email instantly).
# If this variable is missing, the app falls back to DEMO_KEY (rate-limited to
# ~30 req/hour/IP — fine for local dev, bad for anything else).
NASA_API_KEY=DEMO_KEY

# Optional: override the default NASA API base URL.
# NASA_API_BASE_URL=https://api.nasa.gov

# Optional: override the public site URL (used for metadata / OpenGraph).
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
